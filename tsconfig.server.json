{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist-server",
    "noEmit": false,
    "allowJs": false,
    "isolatedModules": false,
    "allowImportingTsExtensions": false
  },
  "include": ["server/**/*.ts"]
}
